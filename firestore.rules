rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Admin collection — no client access.
    // Cloud Functions use the Admin SDK which bypasses these rules.
    // Store the family PIN, TURN credentials, and rate-limit counters here.
    match /admin/{doc} {
      allow read, write: if false;
    }

    // Users — any authenticated user can read all users.
    // Users can only write their own document (keyed by Firebase Auth UID).
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Calls — any authenticated user can create or read call documents.
    // Deletion is restricted to the caller or callee encoded in the document
    // ID (format: "{callerId}_{calleeId}") to prevent one device from
    // hanging up someone else's call.
    match /calls/{callId} {
      allow read, create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null &&
        (request.auth.uid == callId.split('_')[0] ||
         request.auth.uid == callId.split('_')[1]);
    }

    // Call subcollections (ICE candidates for WebRTC signaling).
    // Same participant restriction applies to deletes.
    match /calls/{callId}/{subcol}/{docId} {
      allow read, create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null &&
        (request.auth.uid == callId.split('_')[0] ||
         request.auth.uid == callId.split('_')[1]);
    }
  }
}
