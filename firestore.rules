rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Admin collection — no client access.
    // Cloud Functions use the Admin SDK which bypasses these rules.
    // Store the family PIN and TURN credentials here.
    match /admin/{doc} {
      allow read, write: if false;
    }

    // Users — any authenticated user can read all users.
    // Users can only write their own document (keyed by Firebase Auth UID).
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Calls — any authenticated user can create, read, and delete calls.
    match /calls/{callId} {
      allow read, write: if request.auth != null;
    }

    // Call subcollections (ICE candidates for WebRTC signaling)
    match /calls/{callId}/{subcol}/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
