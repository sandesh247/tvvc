rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Admin collection — no client access.
    // Cloud Functions use the Admin SDK which bypasses these rules.
    // Store the family PIN, TURN credentials, and rate-limit counters here.
    match /admin/{doc} {
      allow read, write: if false;
    }

    // Users — any authenticated user can read all users.
    // Users can only write their own document (keyed by Firebase Auth UID).
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId}/private/secrets {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Calls — restricted to caller or callee.
    match /calls/{callId} {
      allow create: if request.auth != null && request.resource.data.callerId == request.auth.uid;
      // Allow read if resource == null to permit `get()` checks in Firestore transactions during call initiation.
      // Otherwise, restrict read to the caller or callee.
      allow read: if request.auth != null && (resource == null || resource.data.callerId == request.auth.uid || resource.data.calleeId == request.auth.uid);
      allow update, delete: if request.auth != null &&
        (resource.data.callerId == request.auth.uid || resource.data.calleeId == request.auth.uid);
    }

    // Call subcollections (ICE candidates for WebRTC signaling).
    match /calls/{callId}/{subcol}/{docId} {
      // The hyphen '-' in the character class must be placed at the end: `[a-zA-Z0-9_-]`
      // If placed in the middle like `[a-zA-Z0-9-_]`, RE2 interprets it as a range from '9' to '_',
      // which excludes the literal '-' and causes UUIDs (which contain hyphens) to fail the check.
      allow read, write: if request.auth != null &&
        request.auth.uid.matches('^[a-zA-Z0-9_-]+$') &&
        (callId.matches('^' + request.auth.uid + '_[a-zA-Z0-9_-]+$') || 
         callId.matches('^[a-zA-Z0-9_-]+_' + request.auth.uid + '$') ||
         callId.matches('^[a-zA-Z0-9_-]+_' + request.auth.uid + '_[a-zA-Z0-9_-]+$'));
    }

    // Client errors — write-only collection for client-side crash/error logs.
    match /client_errors/{docId} {
      allow create: if request.resource.data.message is string &&
                      request.resource.data.stack is string &&
                      request.resource.data.timestamp is timestamp &&
                      request.resource.data.userAgent is string &&
                      request.resource.data.appVersion is string &&
                      (request.resource.data.context == null || request.resource.data.context is string);
      allow read, update, delete: if false;
    }
  }
}
